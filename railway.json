{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r backend/requirements.txt gunicorn"
  },
  "deploy": {
    "startCommand": "gunicorn backend.app:create_app --worker-class gevent --bind 0.0.0.0:$PORT --timeout 30 --workers 2",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
